# UniSource
UNISOURCE_URL = "https://api.unisource.example"
UNISOURCE_SERVICE_ID = "SERVICE_ID"
UNISOURCE_API_KEY = "API_KEY"

# Appwrite
# Use the releases Appwrite project values here; the app uses one unified Appwrite config.
PUBLIC_APPWRITE_PROJECT_ID = "PROJECT_ID"
PUBLIC_APPWRITE_PROJECT_NAME = "PROJECT_NAME"
PUBLIC_APPWRITE_ENDPOINT = "https://<region>.cloud.appwrite.io/v1"
# Required Appwrite scopes: sessions.write plus any admin data scopes used by this app.
APPWRITE_API_KEY = "APPWRITE_API_KEY"

# Cloudflare
R2_ENDPOINT = "R2_ENDPOINT"
R2_ACCESS_KEY_ID = "R2_ACCESS_KEY_ID"
R2_SECRET_ACCESS_KEY = "R2_SECRET_ACCESS_KEY"
R2_BUCKET_NAME = "R2_BUCKET_NAME"

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL = "https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN = "xxx"
