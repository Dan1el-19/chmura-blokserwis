		"@aws-sdk/s3-request-presigner": "^3.974.0",
		"@internationalized/date": "^3.10.1",
		"@svelte-plugins/datepicker": "^1.0.11",
		"@types/archiver": "^7.0.0",
		"@uppy/aws-s3": "^5.1.0",
		"@uppy/core": "^5.2.0",
		"@uppy/dashboard": "^5.1.0",
		"@uppy/golden-retriever": "^5.2.1",
		"@uppy/svelte": "^5.0.2",
		"@upstash/ratelimit": "^2.0.8",
