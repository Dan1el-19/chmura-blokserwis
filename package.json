{
	"name": "chmura-blokserwis",
	"private": true,
	"version": "2.1.1",
	"packageManager": "pnpm@11.0.9",
	"type": "module",
	"scripts": {
		"dev": "pnpm sdk:link && vite dev --host",
		"db:init": "npx vite-node scripts/init-db.ts",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "pnpm test:unit -- --run && pnpm test:e2e",
		"test:e2e": "playwright test",
		"sdk:build": "pnpm --dir ../UniSource/packages/unisource-sdk build",
		"sdk:dev": "pnpm --dir ../UniSource/packages/unisource-sdk dev",
		"sdk:link": "node scripts/link-unisource-sdk.mjs",
		"sdk:unlink": "pnpm install --frozen-lockfile",
		"deploy": "pnpm run build && wrangler deploy"
	},
	"pnpm": {
		"overrides": {
			"@smithy/smithy-client": "4.13.0"
		}
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260507.1",
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.6",
		"@semantic-release/npm": "^13.1.5",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.2.4",
		"@types/bcrypt": "^6.0.0",
		"@types/content-disposition": "^0.5.9",
		"@types/node": "^25.6.1",
		"@vitest/browser-playwright": "^4.1.5",
		"conventional-changelog-conventionalcommits": "^9.3.1",
		"dotenv": "^17.4.2",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.4",
		"semantic-release": "^25.0.3",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.2.4",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.11",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.5",
		"vitest-browser-svelte": "^2.1.1",
		"wrangler": "^4.90.0"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1045.0",
		"@aws-sdk/s3-request-presigner": "^3.1045.0",
		"@internationalized/date": "^3.12.1",
		"@unisource/sdk": "^0.4.0",
		"@uppy/aws-s3": "^5.1.0",
		"@uppy/core": "^5.2.0",
		"@uppy/golden-retriever": "^5.0.0",
		"@upstash/ratelimit": "^2.0.8",
		"@upstash/redis": "^1.38.0",
		"appwrite": "^24.2.0",
		"bcrypt": "^6.0.0",
		"bits-ui": "^2.18.1",
		"content-disposition": "^1.1.0",
		"node-appwrite": "^23.1.0",
		"phosphor-svelte": "^3.1.0",
		"svelte-sonner": "^1.1.1",
		"tiny-lru": "^13.0.0",
		"zod": "^4.4.3"
	}
}
