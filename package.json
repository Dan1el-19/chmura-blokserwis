{
	"name": "effinity-cloud",
	"private": true,
	"version": "1.14.2",
	"packageManager": "pnpm@11.0.8",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"db:init": "npx vite-node scripts/init-db.ts",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "pnpm test:unit -- --run && pnpm test:e2e",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.6",
		"@semantic-release/npm": "^13.1.5",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/bcrypt": "^6.0.0",
		"@types/content-disposition": "^0.5.9",
		"@types/node": "^25.6.0",
		"@types/uuid": "^11.0.0",
		"@vitest/browser-playwright": "^4.1.4",
		"dotenv": "^17.4.2",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.5.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.2",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"semantic-release": "^25.0.3",
		"svelte": "^5.55.3",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.8",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.4",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1029.0",
		"@aws-sdk/lib-storage": "^3.1029.0",
		"@aws-sdk/s3-request-presigner": "^3.1029.0",
		"@internationalized/date": "^3.12.0",
		"@svelte-plugins/datepicker": "^1.0.11",
		"@types/archiver": "^7.0.0",
		"@uppy/aws-s3": "^5.1.0",
		"@uppy/core": "^5.2.0",
		"@uppy/dashboard": "^5.1.1",
		"@uppy/golden-retriever": "^5.2.1",
		"@uppy/svelte": "^5.2.0",
		"@upstash/ratelimit": "^2.0.8",
		"@upstash/redis": "^1.37.0",
		"appwrite": "^24.1.1",
		"archiver": "^7.0.1",
		"bcrypt": "^6.0.0",
		"bits-ui": "^2.17.3",
		"content-disposition": "^1.1.0",
		"date-fns": "^4.1.0",
		"node-appwrite": "^23.1.0",
		"phosphor-svelte": "^3.1.0",
		"svelte-sonner": "^1.1.0",
		"tiny-lru": "^13.0.0",
		"uuid": "^13.0.0",
		"zod": "^4.3.6"
	}
}
